# CodeGen Studio Configuration Example
# ====================================
# Copy this file to .env and modify values

# Application
APP_NAME=CodeGen Studio
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=info
DEBUG=false

# Java Configuration
JAVA_ENABLED=true
JAVA_PORT=7070
JAVA_DEBUG_PORT=5005
JAVA_OPTS=-Xmx2G -XX:+UseG1GC -Djava.awt.headless=true
JAVA_HOME=./resources/jvm

# AI Configuration
AI_ENABLED=false
AI_MODEL_PATH=./resources/ai-models/codellama-7b-q4.gguf
AI_MODEL_URL=https://huggingface.co/TheBloke/CodeLlama-7B-GGUF/resolve/main/codellama-7b.Q4_K_M.gguf
AI_CONTEXT_SIZE=4096
AI_THREADS=4
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.1

# Privacy & Security
NETWORK_BLOCKING=true
TELEMETRY=false
AUTO_UPDATES=false
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY=your-secure-encryption-key-here
AUDIT_LOGGING=true

# Paths
PROJECTS_DIR=./projects
TEMPLATES_DIR=./java-backend/src/main/resources/templates
DATA_DIR=./data
LOGS_DIR=./logs

# UI & Editor
THEME=dark
EDITOR_FONT_SIZE=14
EDITOR_TAB_SIZE=2
EDITOR_WORD_WRAP=true

# Development
TAURI_DEBUG=false
DEV_SERVER_PORT=1420

# Testing
TEST_TIMEOUT=30000
TEST_AI_MODEL_PATH=./resources/ai-models/test-model.gguf

# Performance
MAX_FILE_SIZE=10485760
MAX_PROJECTS=50
