spring:
  application:
    name: {{projectName}}
  
  datasource:
    url: jdbc:h2:mem:{{projectName}}db
    driver-class-name: org.h2.Driver
    username: sa
    password: 
  
  h2:
    console:
      enabled: true
      path: /h2-console
  
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.H2Dialect
        format_sql: true

server:
  port: 8080
  servlet:
    context-path: /

logging:
  level:
    com.{{packageName}}: DEBUG
    org.springframework: INFO
